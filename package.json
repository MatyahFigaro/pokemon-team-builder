{
  "name": "pokemon-team-builder",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "cli": "pnpm --filter @pokemon/cli dev",
    "cli:analyze": "pnpm --filter @pokemon/cli dev analyze",
    "cli:patch": "pnpm --filter @pokemon/cli dev suggest-patch",
    "cli:normalize": "pnpm --filter @pokemon/cli dev normalize"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
